Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"uP2", " ", "=", " ", 
   RowBox[{"SolveParabolicPDE2D", "[", 
    RowBox[{"1.", ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0.", ",", " ", "1.", ",", " ", "9"}], "}"}], 
     ",", " ", 
     RowBox[{"{", 
      RowBox[{"y", ",", " ", "0.", ",", " ", "1.", ",", " ", "9"}], "}"}], 
     ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0.", ",", " ", "0.01", ",", " ", "10"}], "}"}], 
     ",", "\n", "  ", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y"}], "}"}], ",", " ", 
       RowBox[{
        RowBox[{"Sin", "[", 
         RowBox[{"Pi", " ", "x"}], "]"}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"Pi", " ", "y"}], "]"}]}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"y", ",", " ", "0."}], "]"}], ",", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"y", ",", " ", "0."}], "]"}], ",", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"x", ",", " ", "0."}], "]"}], ",", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"x", ",", " ", "0."}], "]"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"MatrixPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"uP2", "[", "\"\<Solution\>\"", "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"-", "1"}], "]"}], "]"}], ",", " ", 
   RowBox[{"ColorFunction", " ", "->", " ", "\"\<TemperatureMap\>\""}], ",", 
   "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\"\<2D Heat, final time slice\>\""}]}], 
  "]"}]}], "Input",
