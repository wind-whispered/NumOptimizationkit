Cell[BoxData[
 RowBox[{
  RowBox[{"R", " ", "=", " ", 
   RowBox[{"PadeApproximate", "[", 
    RowBox[{"Exp", ",", " ", "0.", ",", " ", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", "3"}], "}"}]}], "]"}]}], ";"}]], "Input",Expressi\
onUUID->"234ad24e-6800-4567-b53d-f4277f4b723e"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
