Cell["FindConstrainedMinimum -- box and equality constraints", "Subsection",ExpressionUUID->"7b391009-47ac-4e0e-ad3e-4de7b2647282"],

Cell["\<\
Box constraint: minimize x^2+y^2 with 1 <= x,y <= 5 -> minimum at (1,1):\
\>", "Text",ExpressionUUID->"3c3854c8-c050-4560-98cb-be3eb0f51eb0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindConstrainedMinimum", "[", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{"x", ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "^", "2"}]}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"1.", ",", " ", "1."}], "}"}], ",", "\n", "  ", 
   RowBox[{"LowerBounds", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1.", ",", " ", "1."}], "}"}]}], ",", " ", 
   RowBox[{"UpperBounds", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"5.", ",", " ", "5."}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"488bc360-a64a-41fc-af38-399506a2d748"],

