Cell[CellGroupData[{

Cell["PDE Numerical Solutions", "Section",ExpressionUUID->"585ca8d1-0677-4d25-9a6b-f0381de4f387"],

Cell[CellGroupData[{

Cell["SolveParabolicPDE -- heat equation u_t = alpha^2 u_xx", "Subsection",ExpressionUUID->"408c9401-946e-41e6-912b-abf4f24a420d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ic", " ", "=", " ", 
   RowBox[{"Function", "[", 
    RowBox[{"x", ",", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"Pi", " ", "x"}], "]"}]}], "]"}]}], ";", " ", 
  RowBox[{"bc", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Function", "[", 
      RowBox[{"t", ",", " ", "0."}], "]"}], ",", " ", 
     RowBox[{"Function", "[", 
      RowBox[{"t", ",", " ", "0."}], "]"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9898700728160925`*^9, 3.9898700741891203`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"414df5ce-b22a-47fd-b780-0a2b88252483"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"u1", " ", "=", " ", 
   RowBox[{"SolveParabolicPDE", "[", 
    RowBox[{"1.", ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0.", ",", " ", "1.", ",", " ", "49"}], "}"}], 
     ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0.", ",", " ", "0.1", ",", " ", "100"}], "}"}], 
     ",", " ", "ic", ",", " ", "bc", ",", "\n", "  ", 
     RowBox[{"Method", " ", "->", " ", "\"\<CrankNicolson\>\""}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"MatrixPlot", "[", 
  RowBox[{
