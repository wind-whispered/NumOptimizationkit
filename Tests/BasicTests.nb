 CellLabel->"Out[21]=",ExpressionUUID->"0af6cfdb-7fb6-4ba8-8821-6f585b342160"]
}, Open  ]],

Cell["\<\
Equality constraint h(x)=0: minimize x^2+y^2 subject to x+y=1 -> (0.5,0.5):\
\>", "Text",ExpressionUUID->"0d84ab09-ec98-4477-b0ff-c652d746a95d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindConstrainedMinimum", "[", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{"x", ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "^", "2"}]}]}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"0.5", ",", " ", "0.5"}], "}"}], ",", "\n", "  ", 
   RowBox[{"EqualityConstraints", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"Function", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
        RowBox[{"x", "[", 
         RowBox[{"[", "2", "]"}], "]"}], " ", "-", " ", "1"}]}], "]"}], 
     "}"}]}], ",", "\n", "  ", 
   RowBox[{"Method", " ", "->", " ", "\"\<AugmentedLagrangian\>\""}]}], 
  "]"}]], "Input",
 CellLabel->"In[22]:=",ExpressionUUID->"e725c337-f686-4c61-afc4-0f41a3c04904"],

