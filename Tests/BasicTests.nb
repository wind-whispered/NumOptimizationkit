Cell[CellGroupData[{

Cell["SolveEllipticPDE -- Poisson equation nabla^2 u = f(x,y)", "Subsection",ExpressionUUID->"b2fa836c-9c32-41f4-92bf-a724efda82a3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"uE", " ", "=", " ", 
   RowBox[{"SolveEllipticPDE", "[", 
    RowBox[{
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y"}], "}"}], ",", " ", 
       RowBox[{"-", "2."}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0.", ",", " ", "1.", ",", " ", "9"}], "}"}], 
     ",", " ", 
     RowBox[{"{", 
      RowBox[{"y", ",", " ", "0.", ",", " ", "1.", ",", " ", "9"}], "}"}], 
     ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"y", ",", " ", "0."}], "]"}], ",", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"y", ",", " ", "0."}], "]"}], ",", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"x", ",", " ", "0."}], "]"}], ",", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"x", ",", " ", "0."}], "]"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"MatrixPlot", "[", 
  RowBox[{
   RowBox[{"uE", "[", "\"\<Solution\>\"", "]"}], ",", " ", 
   RowBox[{"ColorFunction", " ", "->", " ", "\"\<TemperatureMap\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"PlotLabel", " ", "->", " ", "\"\<Elliptic PDE\>\""}]}], 
  "]"}]}], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"a7e7ffee-f21f-4640-8c3b-be6e9059d56b"],

