Cell[CellGroupData[{

Cell["SolveHyperbolicPDE -- wave equation u_tt = c^2 u_xx", "Subsection",ExpressionUUID->"4556049f-1e8a-4b19-a8e4-372e6b5f3527"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"uw", " ", "=", " ", 
   RowBox[{"SolveHyperbolicPDE", "[", 
    RowBox[{"1.", ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0.", ",", " ", "1.", ",", " ", "49"}], "}"}], 
     ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0.", ",", " ", "2.", ",", " ", "200"}], "}"}], 
     ",", "\n", "  ", 
     RowBox[{"Function", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"Pi", " ", "x"}], "]"}]}], "]"}], ",", " ", 
     RowBox[{"Function", "[", 
      RowBox[{"x", ",", " ", "0."}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"t", ",", " ", "0."}], "]"}], ",", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"t", ",", " ", "0."}], "]"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"MatrixPlot", "[", 
  RowBox[{
   RowBox[{"uw", "[", "\"\<Solution\>\"", "]"}], ",", " ", 
   RowBox[{"ColorFunction", " ", "->", " ", "\"\<BlueGreenYellow\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"PlotLabel", " ", "->", " ", "\"\<Wave equation\>\""}]}], 
  "]"}]}], "Input",
