Cell[CellGroupData[{

Cell["ScatteredInterpolate -- 2D scattered data:", "Subsection",ExpressionUUID->"6bdc3437-37cc-4591-b6a0-1a20225bfa37"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}]], "Input",ExpressionUUID->\
"3aed375e-8dd0-4dcd-b0a0-abc32251f5df"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pts", "  ", "=", " ", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0.", ",", "1."}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"30", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"vals", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"Pi", " ", 
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "]"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"Pi", " ", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], " ", "&"}], " ", "/@", 
    " ", "pts"}]}], ";"}]}], "Input",ExpressionUUID->"8e40a22b-84d7-4a9d-9e1d-\
1244b8bfa1d4"],

Cell["Thin plate spline (default -- global, C2 smooth):", "Text",ExpressionUUID->"cab7b345-b3d7-4228-a8b0-09aad7bb26ce"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ScatteredInterpolate", "[", 
   RowBox[{"pts", ",", " ", "vals", ",", " ", 
    RowBox[{"{", 
     RowBox[{"0.5", ",", " ", "0.5"}], "}"}]}], "]"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"~", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"Pi", "/", "2"}], "]"}]}], "*", 
     RowBox[{"Cos", "[", 
      RowBox[{"Pi", "/", "2"}], "]"}]}], " ", "=", " ", "0"}], " ", 
   "*)"}]}]], "Input",ExpressionUUID->"d1dd94a7-3060-4591-8c7b-ba00cc032717"],

Cell["Inverse distance weighting:", "Text",ExpressionUUID->"b5faa0d1-9374-4d94-bcbe-42380b33f640"],

Cell[BoxData[
 RowBox[{"ScatteredInterpolate", "[", 
  RowBox[{"pts", ",", " ", "vals", ",", " ", 
   RowBox[{"{", 
    RowBox[{"0.5", ",", " ", "0.5"}], "}"}], ",", " ", 
   RowBox[{"Method", " ", "->", " ", "\"\<InverseDistance\>\""}]}], 
  "]"}]], "Input",ExpressionUUID->"91e10710-df9b-4d41-8c6d-f77abb575128"],

Cell["Nearest neighbour:", "Text",ExpressionUUID->"79522d54-5089-43a0-85fa-c09aaf987abd"],

Cell[BoxData[
 RowBox[{"ScatteredInterpolate", "[", 
  RowBox[{"pts", ",", " ", "vals", ",", " ", 
   RowBox[{"{", 
    RowBox[{"0.5", ",", " ", "0.5"}], "}"}], ",", " ", 
