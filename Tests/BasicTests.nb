Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol", " ", "=", " ", 
   RowBox[{"SolveBoundaryValueProblem", "[", 
    RowBox[{"bvpF", ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0.", ",", " ", "Pi"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0.", ",", " ", "0."}], "}"}], ",", " ", "100", ",", "\n", "  ", 
     RowBox[{"Method", " ", "->", " ", "\"\<FiniteDifference\>\""}]}], 
    "]"}]}], ";"}], "\n", 
