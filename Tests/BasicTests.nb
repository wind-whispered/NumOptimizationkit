  "]"}]], "Input",ExpressionUUID->"6e6ab684-dd77-4d42-8f71-0ed3bd39ca65"],

Cell["Batch evaluation at a grid of query points:", "Text",ExpressionUUID->"593e6897-6888-479b-ac88-401750bb94e6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qGrid", " ", "=", " ", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0.1", ",", "0.9", ",", "0.1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "0.1", ",", "0.9", ",", "0.1"}], "}"}]}], "]"}], 
     ",", " ", "1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"gridVals", " ", "=", " ", 
   RowBox[{"ScatteredInterpolate", "[", 
    RowBox[{"pts", ",", " ", "vals", ",", " ", "qGrid"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"Length", "[", "gridVals", "]"}]}], "Input",ExpressionUUID->\
"6d7cc206-cae9-43f5-afcd-012d18ad2411"]
