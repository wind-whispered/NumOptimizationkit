Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"xs3", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"0.", ",", " ", 
     RowBox[{"Pi", "/", "2"}], ",", " ", "Pi"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"HermiteInterpolate", "[", 
   RowBox[{"xs3", ",", " ", 
