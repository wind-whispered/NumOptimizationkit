Cell["Complex-valued ODE: i y' = y, y(0)=1 -> e^{-it}:", "Text",ExpressionUUID->"35e43784-6c9b-4638-948d-a26bebf68d69"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"solZ", " ", "=", " ", 
   RowBox[{"SolveInitialValueProblem", "[", 
    RowBox[{
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", "z"}], "}"}], ",", " ", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "z"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "0.", ",", " ", 
       RowBox[{"2", " ", "Pi"}]}], "}"}], ",", " ", 
     RowBox[{"1.", "+", 
      RowBox[{"0.", "I"}]}], ",", "\n", "  ", 
     RowBox[{"Method", " ", "->", " ", "\"\<RungeKutta4\>\""}], ",", " ", 
     RowBox[{"StepSize", " ", "->", " ", "0.05"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"Last", "[", 
      RowBox[{"solZ", "[", "\"\<Solution\>\"", "]"}], "]"}], "]"}], ",", " ", 
    RowBox[{"Re", "[", 
     RowBox[{
      RowBox[{"solZ", "[", "\"\<Solution\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"|", "y", "|"}], "=", "1"}], ",", " ", 
    RowBox[{
     RowBox[{"y", 
      RowBox[{"(", "0", ")"}]}], "=", "1"}]}], " ", "*)"}]}]}], "Input",
 CellLabel->"In[75]:=",ExpressionUUID->"3c922ed6-37db-4918-9403-5d5d0064eace"],

