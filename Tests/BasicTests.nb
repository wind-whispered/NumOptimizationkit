Cell[CellGroupData[{

Cell["LeastSquaresApproximate -- discrete fitting:", "Subsection",ExpressionUUID->"7e443a4a-8d86-4efe-a414-3028da57be72"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"xs5", " ", "=", " ", 
   RowBox[{"Range", "[", 
    RowBox[{
     RowBox[{"-", "2."}], ",", " ", "2.", ",", " ", "0.5"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"ys5", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"2", " ", "+", " ", 
      RowBox[{"3", " ", "#"}], " ", "-", " ", 
      RowBox[{"#", "^", "2"}]}], " ", "&"}], " ", "/@", " ", "xs5"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"basis", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Function", "[", 
      RowBox[{"x", ",", " ", "1."}], "]"}], ",", " ", 
     RowBox[{"Function", "[", 
      RowBox[{"x", ",", " ", "x"}], "]"}], ",", " ", 
     RowBox[{"Function", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"x", "^", "2"}]}], "]"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"LeastSquaresApproximate", "[", 
   RowBox[{"xs5", ",", " ", "ys5", ",", " ", "basis"}], "]"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"should", " ", 
    RowBox[{"give", " ", "~", 
     RowBox[{"{", 
      RowBox[{"2", ",", "3", ",", 
       RowBox[{"-", "1"}]}], "}"}]}]}], " ", "*)"}]}]}], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"2fe44579-a34a-405a-a923-f40fb7a54948"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.9999999999999996`", ",", "3.`", ",", 
   RowBox[{"-", "0.9999999999999999`"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9898689696977015`*^9, 3.989870584061143*^9, 
  3.9898717977133965`*^9, 3.989872273949939*^9},
 CellLabel->"Out[5]=",ExpressionUUID->"9aa44635-2a2b-49fc-933f-9d4009a30800"]
}, Open  ]],

Cell["QR-based variant (more stable for ill-conditioned data):", "Text",ExpressionUUID->"17a4df72-959c-431e-8d35-173484f4ea6c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LeastSquaresApproximate", "[", 
