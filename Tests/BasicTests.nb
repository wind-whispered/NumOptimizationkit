Cell["Accuracy improves exponentially with degree:", "Text",ExpressionUUID->"11fbe206-9419-489b-a6b0-fe0b10653024"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"n", ",", " ", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"ChebyshevApproximate", "[", 
            RowBox[{"Exp", ",", " ", 
             RowBox[{"{", 
              RowBox[{"x", ",", "0.", ",", "2."}], "}"}], ",", " ", "n"}], 
            "]"}], "[", "#", "]"}], " ", "-", " ", 
          RowBox[{"Exp", "[", "#", "]"}]}], " ", "&"}], "/@", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"0.", ",", "2.", ",", "0.1"}], "]"}]}], "]"}], "]"}]}], 
    "}"}], ",", "\n", "  ", 
   RowBox[{"{", 
    RowBox[{"n", ",", " ", 
     RowBox[{"{", 
      RowBox[{"4", ",", " ", "6", ",", " ", "8", ",", " ", "12"}], "}"}]}], 
    "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[136]:=",ExpressionUUID->"6305adaa-c96c-4af9-986f-c9363f9e00ba"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"4", ",", "0.0017388834790939`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"6", ",", "9.840420153395257`*^-6"}], "}"}], ",", 
   RowBox[{"{", 
